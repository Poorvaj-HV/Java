class Solution {
    public ListNode reverseBetween(ListNode head, int left, int right) {
        if (head == null || left == right) return head;

        ListNode dummy = new ListNode(0);
        dummy.next = head;
        ListNode before = dummy;

        // 1. Reach the node right before the reversal starts
        for (int i = 1; i < left; i++) {
            before = before.next;
        }

        // 2. Define the start and end of the segment to be reversed
        ListNode start = before.next;
        ListNode end = start;
        for (int i = 0; i < right - left; i++) {
            end = end.next;
        }

        // 3. Cut the end connection to isolate the segment
        ListNode after = end.next;
        end.next = null;

        // 4. REVERSE LOGIC
        ListNode prev = start;
        ListNode curr = start.next;
        while (curr != null) {
            ListNode next = curr.next;
            curr.next = prev;
            prev = curr;
            curr = next;
        }

        // 5. Reconnect the pieces
        before.next = prev; // 'prev' is now the new head of the segment
        start.next = after; // 'start' is now the tail of the segment

        return dummy.next;
    }
}
